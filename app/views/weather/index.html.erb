<div style="font-family: sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;">
  <h1 style="border-bottom: 2px solid #333;">日本全国の天気予報</h1>
  <div id="map" style="height: 500px; width: 100%; margin-top: 20px; border: 1px solid #ccc;"></div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // 1. 地図の初期化（日本全体が見えるように設定）
      const map = L.map('map').setView([36.2048, 138.2529], 5);

      // 2. 地図の背景（タイル）を設定
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors'
      }).addTo(map);

      // 3. Railsから都市データを受け取る（コントローラーで @all_cities を用意しておく）
      const cities = <%= @all_cities.to_json(only: [:id, :jp_name, :latitude, :longitude]).html_safe %>;

      // 4. クラスターグループを作成
      const markers = L.markerClusterGroup();

      // 5. 各都市をマーカーとして追加
      cities.forEach(city => {
        if (city.latitude && city.longitude) {
          const marker = L.marker([city.latitude, city.longitude])
            .bindPopup(`
              <strong>${city.jp_name}</strong><br>
              <a href="/?city_id=${city.id}">この場所の天気を表示</a>
            `);
          markers.addLayer(marker);
        }
      });

      // 6. クラスターを地図に追加
      map.addLayer(markers);
    });
  </script>


  <%# 天気データの表示部分 %>
  <% if @city %>
    <h2><%= @city.jp_name %>の現在の天気</h2>
    
    <% if @weathers.any? %>
      <table style="width: 100%; border-collapse: collapse; margin-top: 10px;">
        <thead>
          <tr style="background: #eee;">
            <th style="border: 1px solid #ccc; padding: 10px;">日時</th>
            <th style="border: 1px solid #ccc; padding: 10px;">天気</th>
            <th style="border: 1px solid #ccc; padding: 10px;">気温</th>
            <th style="border: 1px solid #ccc; padding: 10px;">湿度</th>
          </tr>
        </thead>
        <tbody>
          <% @weathers.each do |weather| %>
            <tr>
              <td style="border: 1px solid #ccc; padding: 10px; text-align: center;">
                <%= weather.datetime.strftime("%m/%d %H:%M") %>
              </td>
              <td style="border: 1px solid #ccc; padding: 10px; text-align: center;">
                <% if weather.icon.present? %>
                  <img src="https://openweathermap.org/img/wn/<%= weather.icon %>@2x.png" alt="天気アイコン" style="width: 50px; height: 50px; vertical-align: middle;">
                <% end %>
                <%= weather.main_jp %>
              </td>
              <td style="border: 1px solid #ccc; padding: 10px; text-align: center;">
                <%= weather.temp %>°C
              </td>
              <td style="border: 1px solid #ccc; padding: 10px; text-align: center;">
                <%= weather.humidity %>%
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p style="color: #666;">まだデータがありません。「天気を表示する」ボタンを押して最新情報を取得してください。</p>
    <% if @city.weather_records.empty? %>
        <%# データがない場合、自動取得を促すか自動実行する処理をコントローラーに書くのがスムーズです %>
    <% end %>
  <% end %>
  
  <% else %>
    <p style="background: #fff3cd; padding: 15px; border-left: 5px solid #ffecb5;">
      上のメニューから都市を選択して、天気をチェックしてみましょう！
    </p>
  <% end %>
</div>